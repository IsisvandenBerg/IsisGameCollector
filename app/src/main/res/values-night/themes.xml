<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.IsisGameCollector" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_primary_variant</item>
        <item name="colorSecondary">@color/purple_accent</item>
        <item name="colorSecondaryVariant">@color/purple_primary</item>
        <item name="colorAccent">@color/purple_accent</item>
        <item name="colorControlActivated">@color/purple_accent</item>
        <item name="colorControlHighlight">@color/purple_highlight</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/lavender</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- ActionBar text and icon colors -->
        <item name="titleTextColor">@color/purple_primary</item>

        <!-- Customize ActionBar -->
        <item name="actionBarStyle">@style/Theme.IsisGameCollector.ActionBar</item>
        <item name="actionBarTheme">@style/Theme.IsisGameCollector.AppBarOverlay</item>
        <item name="actionOverflowButtonStyle">@style/Theme.IsisGameCollector.Overflow</item>
    </style>

    <style name="Theme.IsisGameCollector.ActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/lavender</item>
    </style>

    <style name="Theme.IsisGameCollector.AppBarOverlay" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:textColorPrimary">@color/purple_primary</item>
        <item name="colorControlNormal">@color/purple_primary</item>
        <item name="searchViewStyle">@style/Theme.IsisGameCollector.SearchView</item>
    </style>

    <style name="Theme.IsisGameCollector.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="searchIcon">@android:drawable/ic_menu_search</item>
        <item name="android:tint">@color/purple_primary</item>
    </style>

    <style name="Theme.IsisGameCollector.Overflow" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@color/purple_primary</item>
    </style>
</resources>