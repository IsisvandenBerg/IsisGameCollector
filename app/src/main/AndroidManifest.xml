<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.IsisGameCollector">
        <activity
            android:name=".UI.AccountCreationActivity"
            android:exported="false"
            android:label="Create Account"
            android:parentActivityName=".UI.MainActivity" />
        <activity
            android:name=".UI.PasswordResetActivity"
            android:exported="false"
            android:label="Reset Password"
            android:parentActivityName=".UI.MainActivity" />
        <activity
            android:name=".UI.GameDetails"
            android:label="Game Details"
            android:parentActivityName=".UI.ConsoleDetails"
            android:exported="false" />
        <activity
            android:name=".UI.ConsoleDetails"
            android:exported="false"
            android:label="Console Details"
            android:parentActivityName=".UI.ConsoleList" />
        <activity
            android:name=".UI.ConsoleList"
            android:exported="false"
            android:label="Console List" />
        <activity
            android:name=".UI.MainActivity"
            android:exported="true"
            android:label="Main Activity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
